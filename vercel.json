{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_VERCEL_DEPLOYMENT": "true",
    "NODE_ENV": "production",
    "SKIP_ENV_VALIDATION": "true",
    "DEBUG_COLD_START": "false"
  },
  "functions": {
    "src/app/api/health/route.js": {
      "memory": 128,
      "maxDuration": 5
    },
    "src/app/api/v1/models/route.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "src/app/api/providers/route.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "src/app/api/v1/responses/route.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "src/app/api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "src/app/**/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
